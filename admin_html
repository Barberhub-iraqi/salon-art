function onArtBgChange(e){
  const f=e.target.files[0];if(!f)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    const img=new Image();
    img.onload=()=>{
      const MAX=900;
      let w=img.width,h=img.height;
      if(w>h){if(w>MAX){h=Math.round(h*MAX/w);w=MAX;}}
      else{if(h>MAX){w=Math.round(w*MAX/h);h=MAX;}}
      const canvas=document.createElement('canvas');
      canvas.width=w;canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      _artBgBase64=canvas.toDataURL('image/jpeg',0.65);
      const prev=document.getElementById('art-bg-preview');
      const ph=document.getElementById('art-bg-placeholder');
      prev.src=_artBgBase64;prev.style.display='block';
      if(ph)ph.style.display='none';
    };
    img.src=ev.target.result;
  };reader.readAsDataURL(f);
}
window.onArtBgChange=onArtBgChange;

async function saveArtHero(){
  if(!_artBgBase64){toast('اختار صورة أول');return;}
  const heroPhoto=_artBgBase64;
  try{
    await setDoc(DB,{heroPhoto},{merge:true});
    _artBgBase64=null;
    toast('✅ تم حفظ صورة الغلاف');
  }catch{toast('❌ فشل الحفظ');}
}
window.saveArtHero=saveArtHero;

function onArtSvcPhoto(e,svcId){
  const f=e.target.files[0];if(!f)return;
  const reader=new FileReader();
  reader.onload=ev=>{
    const img=new Image();
    img.onload=()=>{
      const MAX=500;
      let w=img.width,h=img.height;
      if(w>h){if(w>MAX){h=Math.round(h*MAX/w);w=MAX;}}
      else{if(h>MAX){w=Math.round(w*MAX/h);h=MAX;}}
      const canvas=document.createElement('canvas');
      canvas.width=w;canvas.height=h;
      canvas.getContext('2d').drawImage(img,0,0,w,h);
      const base64=canvas.toDataURL('image/jpeg',0.7);
      _artSvcPhotos[svcId]=base64;
      const el=document.getElementById('simg-'+svcId);
      if(el&&el.tagName==='IMG'){el.src=base64;}
      else if(el){const img2=document.createElement('img');img2.id='simg-'+svcId;img2.src=base64;img2.style.cssText='width:100%;height:100%;object-fit:cover;';el.replaceWith(img2);}
    };
    img.src=ev.target.result;
  };reader.readAsDataURL(f);
}
window.onArtSvcPhoto=onArtSvcPhoto;

