<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Salon Art — لوحة التحكم</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;900&family=Cinzel:wght@700;900&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
:root{
  --black:#070705;
  --dark:#0E0E08;
  --card:#141410;
  --card2:#1A1A12;
  --gold:#C9A84C;--gold2:#E8C96A;--gold3:#F5E199;--gold-dim:#7A6020;
  --text:#F0E8D0;--muted:#706858;--border:#222218;--border2:#2E2E1E;
  --green:#2E6030;--red:#6B2020;
}
body{font-family:'Cairo',sans-serif;direction:rtl;background:var(--black);color:var(--text);min-height:100vh;}
.app{padding-bottom:90px;}

/* PIN */
.pin-screen{position:fixed;inset:0;background:var(--black);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;padding:20px;}
.pin-logo{margin-bottom:12px;}
.pin-title{font-family:'Cinzel',serif;font-size:24px;font-weight:900;background:linear-gradient(180deg,var(--gold3),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:4px;text-align:center;}
.pin-sub{font-size:10px;letter-spacing:4px;color:var(--muted);margin-bottom:28px;text-align:center;}
.pin-dots{display:flex;gap:14px;margin-bottom:28px;}
.pin-dot{width:13px;height:13px;border-radius:50%;border:1.5px solid var(--border2);transition:all .12s;}
.pin-dot.on{background:var(--gold);border-color:var(--gold);}
.pin-dot.err{background:#8B2020;border-color:#8B2020;}
.pin-pad{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;width:100%;max-width:240px;}
.pin-btn{background:var(--card);border:1px solid var(--border2);border-radius:12px;padding:16px;font-family:'Cairo',sans-serif;font-size:20px;font-weight:700;color:var(--text);cursor:pointer;text-align:center;transition:all .12s;}
.pin-btn:hover{border-color:rgba(201,168,76,0.3);color:var(--gold);}
.pin-btn:active{transform:scale(.93);}
.pin-btn.del{font-size:15px;color:var(--muted);}
.pin-btn.z{grid-column:2;}
.pin-err{font-size:11px;color:#C0392B;margin-top:14px;opacity:0;transition:opacity .2s;}
.pin-err.show{opacity:1;}
.lockout{background:rgba(107,32,32,0.15);border:1px solid rgba(107,32,32,0.3);border-radius:8px;padding:10px 16px;margin-top:14px;font-size:12px;color:#EF5350;text-align:center;display:none;}
.lockout.show{display:block;}

/* HEADER */
.hdr{background:linear-gradient(160deg,var(--dark),var(--card));border-bottom:1px solid var(--border2);padding:14px 16px;display:flex;align-items:center;justify-content:space-between;max-width:520px;margin:0 auto;}
.hdr-left{display:flex;align-items:center;gap:10px;}
.hdr-brand{font-family:'Cinzel',serif;font-size:16px;font-weight:900;background:linear-gradient(180deg,var(--gold3),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;}
.hdr-sub{font-size:10px;color:var(--muted);margin-top:1px;}
.hdr-badge{background:linear-gradient(135deg,var(--gold-dim),var(--gold));color:var(--black);font-weight:900;font-size:12px;padding:5px 14px;border-radius:30px;}
.logout-btn{background:rgba(107,32,32,0.15);border:1px solid rgba(107,32,32,0.3);border-radius:8px;padding:7px 12px;color:#EF5350;font-family:'Cairo',sans-serif;font-size:11px;font-weight:700;cursor:pointer;}
.sync-row{max-width:520px;margin:0 auto;padding:5px 16px;display:flex;justify-content:space-between;font-size:10px;color:var(--muted);}
.sdot{width:5px;height:5px;border-radius:50%;background:var(--green);display:inline-block;margin-left:4px;animation:pulse 2s infinite;}
@keyframes pulse{0%,100%{opacity:1;}50%{opacity:.3;}}

/* TABS */
.tabs{display:flex;max-width:520px;margin:0 auto;border-bottom:1px solid var(--border2);overflow-x:auto;}
.tabs::-webkit-scrollbar{display:none;}
.tab{flex:1;min-width:56px;padding:10px 6px;text-align:center;font-size:11px;font-weight:700;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;}
.tab.active{color:var(--gold);border-bottom-color:var(--gold);}
.tc{display:none;}
.tc.active{display:block;}

/* STATS MINI */
.mini-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;padding:14px 16px 0;max-width:520px;margin:0 auto;}
.mini-stat{background:var(--card);border:1px solid var(--border2);border-radius:10px;padding:12px 8px;text-align:center;}
.ms-n{font-size:20px;font-weight:900;color:var(--gold);}
.ms-l{font-size:9px;color:var(--muted);margin-top:2px;}

/* SECTION */
.sec{padding:14px 16px 0;max-width:520px;margin:0 auto;}
.sec-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.sec-lbl{font-size:8px;font-weight:700;letter-spacing:4px;color:var(--gold-dim);}
.sec-btns{display:flex;gap:6px;flex-wrap:wrap;}
.sm-btn{background:var(--card);border:1px solid var(--border2);border-radius:7px;color:var(--muted);font-family:'Cairo',sans-serif;font-size:10px;padding:5px 10px;cursor:pointer;}
.sm-btn:hover{border-color:rgba(201,168,76,0.3);color:var(--gold);}

/* SEARCH */
.search{background:var(--black);border:1px solid var(--border2);border-radius:8px;padding:9px 12px;font-family:'Cairo',sans-serif;font-size:13px;color:var(--text);width:100%;outline:none;margin-bottom:10px;}
.search::placeholder{color:var(--muted);}
.search:focus{border-color:rgba(201,168,76,0.3);}

/* DATE TABS */
.dtabs{display:flex;gap:6px;overflow-x:auto;padding-bottom:6px;margin-bottom:12px;}
.dtabs::-webkit-scrollbar{display:none;}
.dtab{background:var(--card);border:1px solid var(--border2);border-radius:7px;padding:6px 12px;color:var(--muted);font-family:'Cairo',sans-serif;font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap;}
.dtab:hover{color:var(--text);}
.dtab.active{background:rgba(201,168,76,0.1);border-color:var(--gold);color:var(--gold);font-weight:900;}

/* CARDS */
.card{background:var(--card);border:1px solid var(--border2);border-radius:12px;padding:15px;margin-bottom:9px;}
.card.late{border-color:rgba(107,32,32,0.5);background:rgba(107,32,32,0.05);}
.card.open{border-color:rgba(0,188,212,0.5);background:rgba(0,188,212,0.05);}
.ctop{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:9px;}
.date-tag{font-size:9px;color:var(--muted);background:var(--card2);border-radius:4px;padding:2px 7px;margin-bottom:4px;display:inline-block;}
.c-name{font-size:16px;font-weight:900;color:var(--text);}
.tag{font-size:9px;border-radius:30px;padding:2px 8px;margin-right:3px;display:inline-block;margin-top:3px;}
.t-ok{color:#66BB6A;background:rgba(102,187,106,0.1);border:1px solid rgba(102,187,106,0.15);}
.t-late{color:#EF5350;background:rgba(239,83,80,0.08);border:1px solid rgba(239,83,80,0.15);}
.t-manual{color:var(--gold);background:rgba(201,168,76,0.08);border:1px solid rgba(201,168,76,0.15);}
.time-chip{background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.2);border-radius:8px;padding:6px 12px;font-size:13px;font-weight:700;color:var(--gold2);white-space:nowrap;flex-shrink:0;}
.svc-chip{font-size:10px;color:var(--muted);background:var(--card2);border-radius:5px;padding:3px 9px;margin-top:4px;display:inline-block;}
.price-chip{font-size:10px;color:#66BB6A;background:rgba(102,187,106,0.07);border:1px solid rgba(102,187,106,0.12);border-radius:5px;padding:3px 9px;margin-top:4px;margin-right:4px;display:inline-block;}
.cinfo{display:flex;gap:14px;flex-wrap:wrap;margin:8px 0;}
.cinfo span{font-size:11px;color:var(--muted);}
.acts{display:flex;gap:6px;}
.wa-btn{flex:1;background:linear-gradient(135deg,#1B5E20,#2E7D32);color:#fff;border:none;border-radius:8px;padding:10px 8px;font-family:'Cairo',sans-serif;font-size:12px;font-weight:900;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;}
.wa-btn:disabled{background:rgba(27,94,32,0.2);color:rgba(27,94,32,0.4);cursor:default;}
.done-btn{background:rgba(46,96,48,0.15);border:1px solid rgba(46,96,48,0.25);border-radius:8px;padding:10px 12px;color:#66BB6A;font-family:'Cairo',sans-serif;font-size:12px;font-weight:700;cursor:pointer;}
.del-btn{background:rgba(107,32,32,0.15);border:1px solid rgba(107,32,32,0.25);border-radius:8px;padding:10px 12px;color:#EF5350;font-family:'Cairo',sans-serif;font-size:12px;font-weight:700;cursor:pointer;}
.late-btn{width:100%;margin-top:7px;background:rgba(107,32,32,0.3);border:1px solid rgba(107,32,32,0.4);border-radius:8px;padding:10px;color:#EF5350;font-family:'Cairo',sans-serif;font-size:12px;font-weight:700;cursor:pointer;}
.note-row{display:flex;gap:6px;margin-top:8px;}
.note-inp{flex:1;background:var(--black);border:1px solid var(--border2);border-radius:7px;padding:7px 10px;font-family:'Cairo',sans-serif;font-size:12px;color:var(--text);outline:none;}
.note-inp:focus{border-color:rgba(201,168,76,0.3);}
.note-save{background:rgba(201,168,76,0.1);border:1px solid rgba(201,168,76,0.2);border-radius:7px;padding:7px 12px;color:var(--gold);font-family:'Cairo',sans-serif;font-size:11px;cursor:pointer;}
.wait-row{margin-top:7px;}
.wait-send-btn{width:100%;background:rgba(201,168,76,0.07);border:1px solid rgba(201,168,76,0.15);border-radius:8px;padding:9px;color:var(--gold);font-family:'Cairo',sans-serif;font-size:11px;font-weight:700;cursor:pointer;}

.cs-free{background:rgba(46,96,48,0.1);color:#4CAF50;}
.cs-bkd{background:rgba(201,168,76,0.1);color:var(--gold);}
.cs-late{background:rgba(107,32,32,0.2);color:#EF5350;}

/* STATS */
.wkly{padding:14px 16px 0;max-width:520px;margin:0 auto;}
.wcard{background:var(--card);border:1px solid var(--border2);border-radius:10px;padding:14px;margin-bottom:9px;}
.wcard-title{font-size:9px;color:var(--muted);letter-spacing:3px;margin-bottom:10px;}
.wrow{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid var(--border2);}
.wrow:last-child{border:none;}
.wday{font-size:11px;color:var(--muted);min-width:90px;}
.wcount{font-size:11px;font-weight:700;color:var(--gold);white-space:nowrap;}
.wbar-wrap{flex:1;margin:0 8px;background:var(--card2);border-radius:3px;height:3px;}
.wbar{height:3px;border-radius:3px;background:linear-gradient(to left,var(--gold-dim),var(--gold));}
.rev-box{background:var(--card);border:1px solid rgba(201,168,76,0.1);border-radius:10px;padding:14px 16px;margin-top:8px;display:flex;justify-content:space-between;align-items:center;}
.rev-box span{font-size:12px;color:var(--muted);}
.rev-box strong{font-size:18px;font-weight:900;color:var(--gold2);}
.stabs{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap;}
.stab{background:var(--card);border:1px solid var(--border2);border-radius:7px;padding:5px 12px;font-size:11px;font-weight:700;color:var(--muted);cursor:pointer;font-family:'Cairo',sans-serif;}
.stab.active{background:rgba(201,168,76,0.08);border-color:rgba(201,168,76,0.3);color:var(--gold);}

/* ACCOUNTS */
.acc-row{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--border2);}
.acc-row:last-child{border:none;}
.acc-lbl{font-size:12px;color:var(--muted);}
.acc-val{font-size:15px;font-weight:900;}
.acc-val.gr{color:#66BB6A;}.acc-val.rd{color:#EF5350;}.acc-val.gd{color:var(--gold2);font-size:18px;}
.exp-item{display:flex;justify-content:space-between;align-items:center;padding:9px 0;border-bottom:1px solid var(--border2);}
.exp-item:last-child{border:none;}
.exp-name{font-size:12px;color:var(--muted);}
.exp-sub{font-size:9px;color:var(--border2);margin-top:1px;}
.exp-amt{font-size:13px;font-weight:700;color:#EF5350;}
.exp-del{background:none;border:none;color:rgba(107,32,32,0.4);cursor:pointer;font-size:14px;padding:0 3px;}
.exp-del:hover{color:#EF5350;}

/* ARCHIVE */
.arc-card{background:rgba(7,7,5,0.7);border:1px solid var(--border2);border-radius:9px;padding:11px 13px;margin-bottom:7px;opacity:.75;}
.arc-lbl{font-size:9px;color:#66BB6A;letter-spacing:2px;margin-bottom:3px;}
.arc-name{font-size:13px;font-weight:700;color:var(--muted);}
.arc-detail{font-size:10px;color:var(--border2);margin-top:3px;}

/* WAITLIST */
.wait-card{background:var(--card);border:1px solid rgba(201,168,76,0.1);border-radius:10px;padding:12px 14px;margin-bottom:7px;display:flex;justify-content:space-between;align-items:center;}
.wait-name{font-size:14px;font-weight:700;color:var(--text);}
.wait-detail{font-size:11px;color:var(--muted);margin-top:2px;}
.notif-btn{background:linear-gradient(135deg,#1B5E20,#2E7D32);color:#fff;border:none;border-radius:7px;padding:8px 12px;font-family:'Cairo',sans-serif;font-size:11px;font-weight:700;cursor:pointer;}

/* SETTINGS */
.scard{background:var(--card);border:1px solid var(--border2);border-radius:10px;padding:14px;margin-bottom:10px;}
.stitle{font-size:12px;font-weight:700;color:var(--gold);margin-bottom:12px;}
.srow{display:flex;flex-direction:column;gap:5px;margin-bottom:9px;}
.slbl{font-size:10px;color:var(--muted);}
.sinp{background:var(--black);border:1px solid var(--border2);border-radius:7px;padding:9px 11px;font-family:'Cairo',sans-serif;font-size:13px;color:var(--text);width:100%;outline:none;}
.sinp:focus{border-color:rgba(201,168,76,0.3);}
.save-btn{background:linear-gradient(135deg,var(--gold-dim),var(--gold));color:var(--black);border:none;border-radius:8px;padding:10px 18px;font-family:'Cairo',sans-serif;font-size:13px;font-weight:900;cursor:pointer;width:100%;}
.dis-scroll{display:flex;gap:6px;overflow-x:auto;padding-bottom:6px;margin-bottom:12px;}
.dis-scroll::-webkit-scrollbar{display:none;}
.dis-day{flex-shrink:0;width:58px;background:var(--card);border:1px solid var(--border2);border-radius:10px;padding:9px 5px;text-align:center;cursor:pointer;transition:all .15s;}
.dis-day.off{background:rgba(107,32,32,0.12);border-color:rgba(107,32,32,0.35);}
.dd-name{font-size:9px;color:var(--muted);display:block;margin-bottom:3px;}
.dis-day.off .dd-name{color:#EF5350;}
.dd-num{font-size:17px;font-weight:900;color:var(--muted);display:block;}
.dis-day.off .dd-num{color:#EF5350;}
.dd-month{font-size:8px;color:var(--muted);display:block;margin-top:1px;}

/* SERVICES EDITOR */
.svc-edit-grid{display:flex;flex-direction:column;gap:8px;}
.svc-edit-row{background:var(--card2);border:1px solid var(--border2);border-radius:9px;padding:10px 12px;display:flex;flex-direction:column;gap:6px;}
.svc-photo-row{display:flex;align-items:center;gap:8px;margin:8px 0;}
.svc-photo-thumb{width:38px;height:38px;border-radius:8px;overflow:hidden;background:var(--black);display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1.5px solid var(--border2);cursor:pointer;}
.svc-photo-thumb img{width:100%;height:100%;object-fit:cover;}
.photo-upload-area{border:1.5px dashed rgba(201,168,76,0.3);border-radius:10px;padding:16px;text-align:center;cursor:pointer;transition:all .2s;margin-bottom:10px;}
.photo-upload-area:hover{border-color:var(--gold);background:rgba(201,168,76,0.04);}
.photo-upload-text{font-size:12px;color:var(--muted);}
.svc-edit-top{display:flex;gap:7px;align-items:center;}
.svc-num{font-size:11px;color:var(--gold-dim);font-weight:700;min-width:22px;}
.svc-icon-inp{width:48px;background:var(--black);border:1px solid var(--border2);border-radius:6px;padding:6px;font-size:16px;text-align:center;color:var(--text);outline:none;}
.svc-name-inp{flex:1;background:var(--black);border:1px solid var(--border2);border-radius:6px;padding:7px 9px;font-family:'Cairo',sans-serif;font-size:13px;color:var(--text);outline:none;}
.svc-name-inp:focus,.svc-icon-inp:focus,.svc-price-inp:focus{border-color:rgba(201,168,76,0.4);}
.svc-price-inp{width:100%;background:var(--black);border:1px solid var(--border2);border-radius:6px;padding:7px 9px;font-family:'Cairo',sans-serif;font-size:13px;color:var(--gold);outline:none;}
.svc-price-lbl{font-size:9px;color:var(--muted);margin-bottom:2px;}

/* BLOCKED SLOTS */
.blk-day-sel{display:flex;gap:6px;overflow-x:auto;padding-bottom:6px;margin-bottom:12px;}
.blk-day-sel::-webkit-scrollbar{display:none;}
.blk-day-pill{flex-shrink:0;background:var(--card);border:1px solid var(--border2);border-radius:8px;padding:7px 13px;color:var(--muted);font-family:'Cairo',sans-serif;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;}
.blk-day-pill.active{background:rgba(201,168,76,0.1);border-color:var(--gold);color:var(--gold);}
.blk-slots-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:6px;margin-bottom:12px;}
.blk-slot{background:var(--card);border:1px solid var(--border2);border-radius:7px;padding:9px 4px;font-family:'Cairo',sans-serif;font-size:11px;font-weight:700;color:var(--muted);cursor:pointer;text-align:center;transition:all .15s;}
.blk-slot:hover{border-color:rgba(239,83,80,0.4);color:#EF5350;}
.blk-slot.blocked{background:rgba(107,32,32,0.25);border-color:rgba(239,83,80,0.5);color:#EF5350;}
.blk-slot.booked{opacity:.4;cursor:not-allowed;}

/* MISC */
.empty{text-align:center;padding:40px 0;border:1px dashed var(--border2);border-radius:12px;}
.empty-icon{font-size:32px;margin-bottom:10px;opacity:.3;}
.empty p{color:var(--muted);font-size:13px;}
.loader-app{position:fixed;inset:0;background:var(--black);display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:997;}
.loader-ring{width:44px;height:44px;border:2px solid var(--border);border-top-color:var(--gold);border-radius:50%;animation:spin 1s linear infinite;}
@keyframes spin{to{transform:rotate(360deg)}}
.loader-app p{margin-top:14px;font-size:11px;color:var(--muted);letter-spacing:3px;}
.toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:linear-gradient(135deg,var(--gold-dim),var(--gold));color:var(--black);padding:10px 24px;border-radius:30px;font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;z-index:9999;white-space:nowrap;display:none;box-shadow:0 4px 20px rgba(201,168,76,0.35);}
</style>
</head>
<body>

<!-- PIN -->
<div id="pinScreen" class="pin-screen">
  <div class="pin-logo">
    <div style="width:110px;height:110px;border:1px solid #c9a84c44;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 0 60%;background:radial-gradient(circle,#1a1208,#0a0a0a);"><svg width="80" height="80" viewBox="0 0 160 160" fill="none"><circle cx="80" cy="80" r="72" stroke="#c9a84c" stroke-width="1.2" fill="none"/><line x1="48" y1="50" x2="112" y2="106" stroke="#c9a84c" stroke-width="4" stroke-linecap="round"/><line x1="112" y1="50" x2="48" y2="106" stroke="#e8c96a" stroke-width="4" stroke-linecap="round"/><circle cx="48" cy="106" r="12" stroke="#c9a84c" stroke-width="2.5" fill="none"/><circle cx="112" cy="106" r="12" stroke="#e8c96a" stroke-width="2.5" fill="none"/><circle cx="80" cy="77" r="7" fill="#0d0d0d" stroke="#c9a84c" stroke-width="2.5"/><circle cx="80" cy="77" r="2.8" fill="#c9a84c"/></svg></div>
  </div>
  <div class="pin-title">SALON ART</div>
  <div class="pin-sub">أدخل رمز الدخول</div>
  <div class="pin-dots">
    <div class="pin-dot" id="d0"></div><div class="pin-dot" id="d1"></div>
    <div class="pin-dot" id="d2"></div><div class="pin-dot" id="d3"></div>
  </div>
  <div class="pin-pad">
    <button class="pin-btn" onclick="pp('1')">1</button><button class="pin-btn" onclick="pp('2')">2</button><button class="pin-btn" onclick="pp('3')">3</button>
