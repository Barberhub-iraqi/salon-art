function cleanOld(){
  const t=todayK();
  const toRemove=data.bookings.filter(b=>{
    if(!b.dateKey)return true;
    const h=SH[b.slot];
    const isMidnight=b.slot&&b.slot.includes('ص')&&h!==undefined&&h<12;
    if(isMidnight){const nd=new Date(b.dateKey+'T00:00:00');nd.setDate(nd.getDate()+1);return dk(nd)<t;}
    return b.dateKey<t;
  });
  // أرشفة الحجوزات القديمة قبل حذفها — بس لو في شيء يتحرك
  if(toRemove.length){
    if(!data.archivedBookings)data.archivedBookings=[];
    let added=false;
    toRemove.forEach(b=>{if(!data.archivedBookings.find(a=>a.id===b.id)){data.archivedBookings.push({...b,autoArchived:true,completedAt:b.completedAt||Date.now()});added=true;}});
    data.bookings=data.bookings.filter(b=>!toRemove.find(r=>r.id===b.id));
    return added; // أرجع true لو في تغيير فعلي
  }
  return false;
}
