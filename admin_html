<script>
// PIN — مع تشفير hash
const P_KEY='art_pin_h';const L_KEY='art_lockout';const F_KEY='art_fails';
async function hashPin(p){const enc=new TextEncoder().encode(p);const buf=await crypto.subtle.digest('SHA-256',enc);return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');}
async function getP(){return localStorage.getItem(P_KEY)||await hashPin('1234');}
async function setP(v){localStorage.setItem(P_KEY,await hashPin(v));}
// migrate plain PIN if exists
(async()=>{const old=localStorage.getItem('art_pin');if(old&&!localStorage.getItem(P_KEY)){await setP(old);localStorage.removeItem('art_pin');}})();
function locked(){return Date.now()<parseInt(localStorage.getItem(L_KEY)||'0');}
function lockLeft(){return Math.ceil((parseInt(localStorage.getItem(L_KEY)||'0')-Date.now())/1000);}
let pe='';
function pp(d){if(locked()){const el=document.getElementById('lockout');el.textContent='🔒 محظور '+lockLeft()+' ثانية';el.classList.add('show');return;}if(pe.length>=4)return;pe+=d;updDots();if(pe.length===4)setTimeout(chkP,120);}
function pd(){pe=pe.slice(0,-1);updDots();}
function updDots(){for(let i=0;i<4;i++){const d=document.getElementById('d'+i);d.classList.toggle('on',i<pe.length);d.classList.remove('err');}}
async function chkP(){if(locked()){pe='';updDots();return;}const h=await hashPin(pe);const stored=await getP();if(h===stored){localStorage.removeItem(F_KEY);document.getElementById('pinScreen').style.display='none';document.getElementById('loaderApp').style.display='flex';window._init&&window._init();}else{const f=(parseInt(localStorage.getItem(F_KEY)||'0'))+1;localStorage.setItem(F_KEY,f);if(f>=5){localStorage.setItem(L_KEY,Date.now()+30000);localStorage.removeItem(F_KEY);const el=document.getElementById('lockout');el.textContent='🔒 مقفل 30 ثانية';el.classList.add('show');}for(let i=0;i<4;i++)document.getElementById('d'+i).classList.add('err');document.getElementById('pinErr').classList.add('show');setTimeout(()=>{pe='';updDots();document.getElementById('pinErr').classList.remove('show');},700);}}
function doLogout(){document.getElementById('mainApp').style.display='none';document.getElementById('pinScreen').style.display='flex';pe='';updDots();}
window.pp=pp;window.pd=pd;window.doLogout=doLogout;
// دعم لوحة المفاتيح للـ PIN
document.addEventListener('keydown',e=>{if(document.getElementById('pinScreen').style.display==='none')return;if(e.key>='0'&&e.key<='9')pp(e.key);else if(e.key==='Backspace')pd();});
</script>

