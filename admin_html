function waitInfo(id){
  const b=data.bookings.find(x=>x.id===id);
  if(!b||b.dateKey!==todayK())return null;
  const active=data.bookings.filter(x=>!x.cancelled&&x.dateKey===b.dateKey).sort((a,z)=>{
    const ta=slotDateTime(a.dateKey,a.slot)||new Date(0);
    const tz=slotDateTime(z.dateKey,z.slot)||new Date(0);
    return ta-tz;
  });
  const idx=active.findIndex(x=>x.id===id);
  if(idx<0)return{before:0,mins:0};
  const mins=active.slice(0,idx).reduce((sum,x)=>sum+getSvcDuration(x.serviceId),0);
  return{before:idx,mins};
}
